# Adlaire License Server — Access Control

# Rewrite API requests to index.php
RewriteEngine On
RewriteCond %{REQUEST_FILENAME} !-f
RewriteCond %{REQUEST_FILENAME} !-d
RewriteRule ^api/(.*)$ index.php [QSA,L]

# Block direct access to data and src directories
RedirectMatch 403 ^.*/data/
RedirectMatch 403 ^.*/src/
RedirectMatch 403 ^.*/templates/

Options -Indexes
