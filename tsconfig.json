{
  "compilerOptions": {
    "target": "ES2021",
    "module": "none",
    "ignoreDeprecations": "6.0",
    "lib": ["ES2021", "DOM", "DOM.Iterable"],
    "strict": true,
    "outDir": "./js",
    "rootDir": "./ts",
    "sourceMap": false,
    "noEmitOnError": true,
    "forceConsistentCasingInFileNames": true,
    "skipLibCheck": true,
    "noFallthroughCasesInSwitch": true
  },
  "include": ["ts/**/*.ts"]
}
