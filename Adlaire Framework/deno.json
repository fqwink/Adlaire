{
  "name": "adlaire-framework",
  "version": "0.0.0",
  "exports": "./src/mod.ts",
  "tasks": {
    "check": "deno check src/mod.ts",
    "test": "deno test --allow-read --allow-net",
    "dev": "deno run --allow-read --allow-net --watch src/mod.ts"
